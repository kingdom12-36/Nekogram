<?xml version="1.0" encoding="utf-8"?>
<!--
  Nekogram floating button — 3D push-button feel.
  Two layers: coloured shadow beneath + lit surface on top.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Coloured drop shadow (gives the button a "colour glow" beneath) -->
    <item
        android:left="2dp"
        android:top="4dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape>
            <solid android:color="#552A6496"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>

    <!-- Raised surface with top-edge rim light -->
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="2dp"
        android:bottom="4dp">
        <shape>
            <gradient
                android:startColor="#FF4A90D9"
                android:endColor="#FF2A5FA8"
                android:angle="270"/>
            <corners android:radius="24dp"/>
            <stroke
                android:width="1dp"
                android:color="#33FFFFFF"/>
        </shape>
    </item>

</layer-list>