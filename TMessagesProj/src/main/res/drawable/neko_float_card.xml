<?xml version="1.0" encoding="utf-8"?>
<!--
  Nekogram floating card — reusable background for settings rows,
  bottom sheets, and any panel that should feel elevated and 3D.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Drop shadow — offset gives lift illusion -->
    <item
        android:left="2dp"
        android:top="4dp"
        android:right="2dp"
        android:bottom="0dp">
        <shape>
            <solid android:color="#40000000"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>

    <!-- Secondary softer shadow for realistic falloff -->
    <item
        android:left="4dp"
        android:top="8dp"
        android:right="4dp"
        android:bottom="0dp">
        <shape>
            <solid android:color="#20000000"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>

    <!-- Glass surface: dark gradient + semi-transparent white rim light -->
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="8dp">
        <shape>
            <gradient
                android:startColor="#FF252836"
                android:endColor="#FF1A1D26"
                android:angle="135"/>
            <corners android:radius="16dp"/>
            <stroke
                android:width="1dp"
                android:color="#1AFFFFFF"/>
        </shape>
    </item>

</layer-list>